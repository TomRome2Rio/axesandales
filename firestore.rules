rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isMemberOrAdmin() {
      return request.auth != null &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isMember == true ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }

    function validSwapMeetStallCount() {
      return request.resource.data.stallCount is int &&
             request.resource.data.stallCount >= 1 &&
             request.resource.data.stallCount <= 4;
    }

    function validSwapMeetAmount() {
      return request.resource.data.amountOwed ==
             ((isMemberOrAdmin() ? request.resource.data.stallCount - 1 : request.resource.data.stallCount) * 10);
    }

    function validSwapMeetUserPaymentStatus() {
      return (request.resource.data.amountOwed == 0 &&
              request.resource.data.paid == true &&
              request.resource.data.status == 'confirmed') ||
             (request.resource.data.amountOwed > 0 &&
              request.resource.data.paid == false &&
              request.resource.data.status == 'pending');
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    match /bookings/{bookingId} {
      allow read: if true;
      allow write: if isAdmin() || request.auth != null;
    }

    match /tables/{tableId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /terrainBoxes/{boxId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gameSystems/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /eventTags/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /membershipAudit/{entryId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /adminAudit/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin() &&
        request.resource.data.performedBy == request.auth.uid;
      allow update, delete: if false;
    }

    match /swapMeetBookings/{bookingId} {
      allow read: if request.auth != null;
      allow create: if isAdmin() ||
        (request.auth != null &&
         request.resource.data.userId == request.auth.uid &&
         request.resource.data.swapMeetId is string &&
         bookingId == request.resource.data.swapMeetId + '_' + request.auth.uid &&
         validSwapMeetStallCount() &&
         validSwapMeetAmount() &&
         validSwapMeetUserPaymentStatus() &&
         request.resource.data.invoiced == false);
      allow update: if isAdmin() ||
        (request.auth != null &&
         request.auth.uid == resource.data.userId &&
         resource.data.userId == request.auth.uid &&
         request.resource.data.userId == request.auth.uid &&
         request.resource.data.swapMeetId == resource.data.swapMeetId &&
         validSwapMeetStallCount() &&
         validSwapMeetAmount() &&
         request.resource.data.invoiced == resource.data.invoiced &&
         (validSwapMeetUserPaymentStatus() ||
          (request.resource.data.paid == resource.data.paid &&
           request.resource.data.status in ['pending', 'cancelled'])));
      allow delete: if isAdmin();
    }

    match /swapMeetState/{docId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() ||
        (request.auth != null &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['bookedStallCount', 'updatedAt']));
    }

    match /swapMeetAudit/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin() ||
        (request.auth != null &&
         request.resource.data.userId == request.auth.uid &&
         request.resource.data.performedBy == request.auth.uid &&
         request.resource.data.action in ['booked', 'cancelled']);
      allow update, delete: if false;
    }

    match /mail/{document} {
      allow read, write: if false;  // Only Cloud Functions can write
    }
  }
}
