rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isMemberOrAdmin() {
      return request.auth != null &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isMember == true ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }

    function validSwapMeetStallCount() {
      return request.resource.data.stallCount is int &&
             request.resource.data.stallCount >= 1 &&
             request.resource.data.stallCount <= 4;
    }

    function validSwapMeetAmount() {
      return request.resource.data.amountOwed ==
             ((isMemberOrAdmin() ? request.resource.data.stallCount - 1 : request.resource.data.stallCount) * 10);
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    match /bookings/{bookingId} {
      allow read: if true;
      allow write: if isAdmin() || request.auth != null;
    }

    match /tables/{tableId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /terrainBoxes/{boxId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gameSystems/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /eventTags/{tagId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /membershipAudit/{entryId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /swapMeetBookings/{userId} {
      allow read: if request.auth != null;
      allow create: if isAdmin() ||
        (request.auth != null &&
         request.auth.uid == userId &&
         request.resource.data.userId == userId &&
         validSwapMeetStallCount() &&
         validSwapMeetAmount() &&
         request.resource.data.paid == false &&
         request.resource.data.invoiced == false);
      allow update: if isAdmin() ||
        (request.auth != null &&
         request.auth.uid == userId &&
         resource.data.userId == userId &&
         request.resource.data.userId == userId &&
         validSwapMeetStallCount() &&
         validSwapMeetAmount() &&
         request.resource.data.paid == resource.data.paid &&
         request.resource.data.invoiced == resource.data.invoiced);
      allow delete: if isAdmin();
    }

    match /swapMeetState/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /swapMeetAudit/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin() ||
        (request.auth != null &&
         request.resource.data.userId == request.auth.uid &&
         request.resource.data.performedBy == request.auth.uid &&
         request.resource.data.action == 'booked');
      allow update, delete: if false;
    }

    match /mail/{document} {
      allow read, write: if false;  // Only Cloud Functions can write
    }
  }
}
